{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RepoGhost",
  "version": "0.1.0",
  "identifier": "dev.repoghost.repoghost",
  "build": {
    "frontendDist": "../.jac/client/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": [
      "binaries/jac-sidecar.sh",
      "binaries/jac-sidecar.bat",
      "../main.jac",
      "../jac.toml",
      "../app/**/*",
      "../.jac/client/dist/**/*"
    ]
  }
}